# Backend environment variables
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/erp_portal

# Comma-separated list of frontend origins allowed to call the backend
FRONTEND_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173,https://erp-portal-seven.vercel.app

# When true, local backend startup seeds a demo school, teacher, students, and dashboard data.
SEED_LOCAL_DATA=true

# Email Configuration (Gmail or other SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@erp-portal.com

# Alternative email env vars (backward compatibility)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
